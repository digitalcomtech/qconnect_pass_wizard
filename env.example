# QConnect PASS Wizard — environment variables
# Copy to .env and fill values, or export from your shell before `npm start`.
# NEVER commit real .env files.

# -----------------------------------------------------------------------------
# Runtime mode
# -----------------------------------------------------------------------------
# production: require JWT_SECRET, SESSION_SECRET, and Pegasus tokens for ENVIRONMENT
NODE_ENV=development

ENVIRONMENT=qa
TEST_MODE=false

# -----------------------------------------------------------------------------
# Dangerous / deprecated
# -----------------------------------------------------------------------------
# Deprecated name (ignored unless dangerous flag is set):
# ENABLE_CONFIRMATION_FALLBACK=true

# Only if you explicitly accept HTTP 200 "success" without Pegasus confirming:
DANGEROUS_PEGASUS_CONFIRMATION_FALLBACK=false

# -----------------------------------------------------------------------------
# Server
# -----------------------------------------------------------------------------
PORT=8080
HOST=0.0.0.0

# -----------------------------------------------------------------------------
# Auth (required when NODE_ENV=production)
# -----------------------------------------------------------------------------
JWT_SECRET=
SESSION_SECRET=

# -----------------------------------------------------------------------------
# Production Pegasus / SIM (when ENVIRONMENT=production)
# -----------------------------------------------------------------------------
PROD_PEGASUS_BASE_URL=https://qservices.pegasusgateway.com
PROD_PEGASUS_TOKEN=
PROD_PEGASUS1_TOKEN=
PROD_PEGASUS256_TOKEN=
PROD_DEFAULT_GROUP_ID=3367
PROD_DEFAULT_GROUP_ID2=4126
PROD_SIM_ACCOUNT_SID=
PROD_SIM_RATE_PLAN_SID=
PROD_SIM_FLEET_SID=

# -----------------------------------------------------------------------------
# Pegasus auth refresh (npm run pegasus:fetch-tokens → writes .env.local)
# -----------------------------------------------------------------------------
# PEGASUS_AUTH_USERNAME=
# PEGASUS_AUTH_PASSWORD=
# PEGASUS_AUTH_GATEWAY_PEGASUS1=cloud.pegasusgateway.com
# PEGASUS_AUTH_GATEWAY_PEGASUS256=qconnect.qualitas.com.mx
# PEGASUS_AUTH_GATEWAY_QSERVICES=dev2.pegasusgateway.com

# -----------------------------------------------------------------------------
# QA Pegasus / SIM (when ENVIRONMENT=qa)
# -----------------------------------------------------------------------------
QA_PEGASUS_BASE_URL=https://qservices.pegasusgateway.com/qa
QA_PEGASUS_TOKEN=
QA_PEGASUS1_TOKEN=
QA_PEGASUS256_TOKEN=
QA_DEFAULT_GROUP_ID=3441
QA_DEFAULT_GROUP_ID2=3442
QA_SIM_ACCOUNT_SID=
QA_SIM_RATE_PLAN_SID=
QA_SIM_FLEET_SID=

# -----------------------------------------------------------------------------
# API / workflow tuning
# -----------------------------------------------------------------------------
API_TIMEOUT=30000
API_MAX_RETRIES=3
API_RETRY_DELAY=1000
API_RETRY_MULTIPLIER=2
PROXIMITY_RADIUS=200
MAX_DEVICE_WAIT_TIME=1800000
INITIAL_POLL_INTERVAL=10000
MAX_POLL_INTERVAL=120000

# -----------------------------------------------------------------------------
# SIM endpoints / prefixes
# -----------------------------------------------------------------------------
SIM_SUPER_PREFIX=8988
SIM_WIRELESS_PREFIX=8901
SIM_SUPER_ENDPOINT=https://api.pegasusgateway.com/m2m/supersims/v1/Sims
SIM_WIRELESS_ENDPOINT=https://api.pegasusgateway.com/m2m/wireless/v1/Sims
PEGASUS_BASE_URL=https://api.pegasusgateway.com
